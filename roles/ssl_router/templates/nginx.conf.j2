user  nginx;
worker_processes 2;

pid /var/run/nginx.pid;
error_log /dev/stdout warn;

events {
    worker_connections  4048;
    use epoll;
    multi_accept on;
}

http {
    server {
        listen      80 default_server;
        listen      [::]:80 default_server;
        server_name _;

        return 301 https://$host$request_uri;
    }
}

stream {
    map $ssl_preread_server_name $name {
{% for key, value in ssl_router_upstream_map.items() | sort %}
        ~^{{ value.regex }}$    {{ key }};
{% endfor %}
        default              reject;
    }

    upstream reject {
        server 0.0.0.1:1;
    }

{% for key, value in ssl_router_upstream_map.items() | sort %}
    upstream {{ key }} {
        server {{ value.host | default(ansible_facts['default_ipv4']['address']) }}:{{ value.port }};
    }
{% endfor %}

    server {
        listen      [::]:{{ ssl_router_https_port }};
        listen      {{ ssl_router_https_port }};
        proxy_pass  $name;
        proxy_connect_timeout 1s;
        ssl_preread on;
        
        preread_buffer_size {{ ssl_router_preread_buffer_size }};
        proxy_buffer_size {{ ssl_router_proxy_buffer_size }};
    }
}
