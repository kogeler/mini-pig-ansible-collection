# {{ ansible_managed }}
# Decoy site only -- no ACME, no proxy.

{
    auto_https off
    http_port {{ _naive_proxy_decoy_port }}
}

:{{ _naive_proxy_decoy_port }} {
{% if naive_proxy_decoy_upstream_url | default('', true) | length > 0 %}
    # Reverse-proxy mode: forward unauthenticated traffic to a remote decoy.
    # Caddy handles TLS to the upstream and rewrites the Host header so the
    # upstream sees its own hostname. Body/redirect URL rewriting is not done
    # here — pick an upstream whose content does not leak its real domain or
    # add a response-rewriting layer (see README "Limitations").
    reverse_proxy {{ naive_proxy_decoy_upstream_url }} {
        header_up Host {upstream_hostport}
        header_up -X-Forwarded-For
        header_up -X-Forwarded-Proto
        header_up -X-Forwarded-Host
    }
{% else %}
    root * /srv
    file_server
{% endif %}
}
