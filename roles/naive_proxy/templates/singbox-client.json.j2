{#- Sing-box client config rendered by `tasks/clients.yml`.

  Routing notes:
    * `reject ip_cidr 2000::/3` — block IPv6 globals, avoid v6 leaks.
    * `hijack-dns` — pull DNS to the sing-box DNS module
      (only `dns-remote-cloudflare`, DoH detoured through the naive tunnel).
    * `reject port 853` — kill DoT so DNS *cannot* escape via UDP/853 or
      TCP/853; everything funnels back to dns-remote-cloudflare.
    * `reject network=udp port=443` — kill QUIC / HTTP-3. Apps using
      Chromium / OkHttp / wget2 / etc. immediately fall back to HTTP/2
      over TCP, which gets carried through the naive outbound. Without
      this rule QUIC packets hit the next rule (`route udp → direct`)
      and bypass the proxy entirely, defeating the VPN.
    * `route network=udp outbound=direct` — non-443 UDP bypasses the
      naive outbound (which is TCP-only). DNS already handled above.
-#}
{{ {
  'log': {'level': 'info'},
  'dns': {
    'servers': [
      {'type': 'https', 'tag': 'dns-remote-cloudflare',
       'server': '1.1.1.1', 'server_port': 443,
       'detour': 'naive-' ~ _naive_proxy_singbox_user,
       'tls': {'enabled': true,
               'server_name': 'cloudflare-dns.com'}}
    ],
    'final': 'dns-remote-cloudflare',
    'strategy': 'ipv4_only'
  },
  'inbounds': [
    {'type': 'tun', 'tag': 'tun-in',
     'address': ['172.19.0.1/30'],
     'auto_route': true, 'strict_route': true,
     'stack': 'mixed',
     'exclude_package': ['com.android.captiveportallogin']}
  ],
  'outbounds': [
    {'type': 'naive', 'tag': 'naive-' ~ _naive_proxy_singbox_user,
     'server': naive_proxy_external_ip,
     'server_port': naive_proxy_external_port | int,
     'username': _naive_proxy_singbox_user,
     'password': _naive_proxy_singbox_pass,
     'tls': {'enabled': true, 'server_name': naive_proxy_domain}},
    {'type': 'direct', 'tag': 'direct'}
  ],
  'route': {
    'auto_detect_interface': true,
    'rules': [
      {'action': 'sniff'},
      {'action': 'reject', 'ip_cidr': ['2000::/3']},
      {'type': 'logical', 'mode': 'or',
       'rules': [
         {'protocol': 'dns'},
         {'port': [53]}
       ],
       'action': 'hijack-dns'},
      {'action': 'reject', 'port': [853]},
      {'action': 'reject', 'network': ['udp'], 'port': [443]},
      {'action': 'route', 'outbound': 'direct',
       'network': ['udp']}
    ],
    'final': 'naive-' ~ _naive_proxy_singbox_user
  }
} | to_nice_json }}
