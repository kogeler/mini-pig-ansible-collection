[Unit]
Description=Podman container-{{ _naive_proxy_pebble_name }}.service (test ACME CA)
Requires={{ _naive_proxy_pod_unit }}
After=network-online.target {{ _naive_proxy_pod_unit }}
RequiresMountsFor=%t/containers

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Type=notify
NotifyAccess=all
Restart=on-failure
RestartSec=10
TimeoutStartSec=300
TimeoutStopSec=70
Delegate=yes
KillMode=mixed
ExecStartPre=/bin/rm \
        -f %t/%n.ctr-id
ExecStartPre=/bin/sh -c '\
        /usr/bin/podman image exists {{ _naive_proxy_pebble_image }}:{{ _naive_proxy_pebble_image_tag }} \
        || /usr/bin/podman pull {{ _naive_proxy_pebble_image }}:{{ _naive_proxy_pebble_image_tag }}'
ExecStart=/usr/bin/podman container run \
        --cidfile=%t/%n.ctr-id \
        --cgroups=split \
        --sdnotify=conmon \
        --replace \
        --name {{ _naive_proxy_pebble_name }} \
        --pull=never \
        --security-opt=apparmor=unconfined \
        --env PEBBLE_VA_NOSLEEP=1 \
        --volume {{ naive_proxy_config_dir }}/pebble-config.json:/test/config/pebble-config.json:ro{% if naive_proxy_selinux_relabel %},Z{% endif %} \
        --pod={{ _naive_proxy_pod_name }} \
        {{ _naive_proxy_pebble_image }}:{{ _naive_proxy_pebble_image_tag }}
ExecStop=/usr/bin/podman stop \
        --ignore -t 10 \
        --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm \
        -f \
        --ignore -t 10 \
        --cidfile=%t/%n.ctr-id

[Install]
WantedBy=multi-user.target
