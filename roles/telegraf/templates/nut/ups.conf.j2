# Managed by Ansible (kogeler.mini_pig telegraf role) — do not edit by hand.
[{{ telegraf_ups_name }}]
    driver = {{ telegraf_ups_driver }}
    port = {{ telegraf_ups_driver_port }}
{% if telegraf_ups_driver_vendorid | length > 0 %}
    vendorid = {{ telegraf_ups_driver_vendorid }}
{% endif %}
{% if telegraf_ups_driver_productid | length > 0 %}
    productid = {{ telegraf_ups_driver_productid }}
{% endif %}
{% if telegraf_ups_driver_serial | length > 0 %}
    serial = {{ telegraf_ups_driver_serial }}
{% endif %}
{% for opt, val in telegraf_ups_driver_options | dictsort %}
    {{ opt }} = {{ (val | lower) if (val is boolean) else val }}
{% endfor %}
{% if telegraf_ups_description | length > 0 %}
    desc = "{{ telegraf_ups_description }}"
{% endif %}
